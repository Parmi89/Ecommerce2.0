<!DOCTYPE html>
<html>
  <head>
    <title><%= t('app_name') %> | <%= t('meta_title') %></title>  
    <meta name="viewport" content="width=device-width,initial-scale=1">   
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>  
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "/style.css", media: 'all' %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <%= render "shared/notifications" %>
    <%= render 'shared/header' %>
    <% if admin_signed_in? %>
      <%= render 'shared/topBarAdmin' %>
    <% end %>
    <%= render 'shared/topBar' %>
    <%= yield %>
    <%= render 'shared/footer' %>
   
<!-- Asegúrate de que jQuery y Bootstrap JavaScript estén incluidos -->
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>

<script>
  $(document).ready(function() {
    // Activa el acordeón Bootstrap
    $('.accordion-button').on('click', function() {
      // Encuentra el acordeón padre del botón clicado
      var $accordion = $(this).closest('.accordion-item');
      // Encuentra el contenido colapsable dentro del acordeón
      var $collapse = $accordion.find('.accordion-collapse');
      
      // Cierra todos los paneles de acordeón
      $('.accordion-collapse').collapse('hide');
      
      // Abre o cierra el panel de acordeón correspondiente
      $collapse.collapse('toggle');
    });
  });
</script>




  </body>
</html>
