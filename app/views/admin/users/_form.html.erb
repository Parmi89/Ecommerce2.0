<div class="container">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <%= form_with(model: [:admin, @user]) do |form| %>
        <% if @user.errors.any? %>
          <div class="alert alert-danger">
            <h2><%= pluralize(@user.errors.count, "error") %> prohibited this user from being saved:</h2>
            <ul>
              <% @user.errors.each do |error| %>
                <li><%= error.full_message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="form-group">
          <%= form.label :id, t('common.id') %>
          <%= form.number_field :id, class: 'form-control' %>
        </div>

        <div class="form-group">
          <%= form.label :email, t('common.email') %>
          <%= form.email_field :email, class: 'form-control' %>
        </div>

        <div class="form-group">
          <%= form.label :username, t('common.username') %>
          <%= form.text_field :username, class: 'form-control' %>
        </div>

        <div class="form-group">
          <%= form.label :password, t('.change_password') %>
          <%= form.password_field :password, class: 'form-control', placeholder: t('.change_password') %>
        </div>

        <div class="form-group">
          <%= form.label :password_confirmation, t('.confirm_new_password') %>
          <%= form.password_field :password_confirmation, class: 'form-control', placeholder: t('.confirm_new_password') %>
        </div>

        <div class="form-group text-center mt-4">
          <%= form.submit t('common.accept'), class: 'btn btn-primary' %>
        </div>
      <% end %>
    </div>
  </div>
</div>
