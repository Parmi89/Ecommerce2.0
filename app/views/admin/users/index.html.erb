<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <h2 class="text-center mb-4"><%= t('.users_list') %></h2>
      <h5 class="text-center mb-2"><%= t('.total_accounts') %> <%= @users.count %> </h5>
      <%= form_tag(admin_users_path, method: :get, class: "mb-4") do %>
        <div class="input-group">
          <%= text_field_tag :query, params[:query], class: "form-control", placeholder: t('.query_user') %>
        </div>
      <% end %>

      <% if @users.any? %>
        <table class="table mt-4">
          <thead>
            <tr>
              <th class="text-center" style="width: 5%;"><%= t('.id')%></th>
              <th class="text-center" style="width: 15%;"><%= t('.last_name')%></th>
              <th class="text-center" style="width: 15%;"><%= t('.first_name')%></th>
              <th class="text-center" style="width: 20%;"><%= t('common.email')%></th>
              <th class="text-center" style="width: 25%;"><%= t('.accion')%></th>
            </tr>
          </thead>
          <tbody>
             <%= render partial: 'user', collection: @users, locals: { info_users: @info_users } %>
          </tbody>
        </table>
      <% else %>
        <p class="text-center mt-4"><%= t('.no_data')%></p>
      <% end %>
    </div>
  </div>
</div>
