<div class="container">
  <h2><%= t('common.log_in') %></h2>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "form-horizontal" }) do |f| %>
    <div class="form-group">
      <%= f.label :login, t(".email_or_username"), class: "control-label col-sm-4" %>
      <div class="col-sm-10">
        <%= f.text_field :login, class: "form-control", placeholder: t(".email_or_username") %>
      </div>
    </div>

    <div class="form-group">
      <%= f.label :password, t("password"), class: "control-label col-sm-2" %>
      <div class="col-sm-10">
        <%= f.password_field :password, class: "form-control", placeholder: t("password") %>
      </div>
    </div>

    <div class="form-group mt-4">
      <div class="col-sm-offset-2 col-sm-10">
        <%= f.submit t('common.accept'), class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</div>
