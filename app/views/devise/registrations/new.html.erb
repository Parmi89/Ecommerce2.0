<h2><%= t('create_account') =%></h2>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="field">
    <%= f.email_field :email, autofocus: true, placeholder: t("email"),required: true %>
  </div>

  <div class="field">
    <%= f.text_field :username, autofocus: true, placeholder: t("username"),required: true %>
  </div>

    <%= f.password_field :password, placeholder: t('password'),required: true %>
  </div>

  <div class="field">
    <%= f.password_field :password_confirmation, placeholder: t('password_confirm'),required: true %>
  </div>

  <div class="actions">
    <%= f.submit t('common.accept') %>
  </div>
<% end %>